<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 آمار سیستم"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:id="@+id/txtUptime" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="آپ‌تایم: 0 ثانیه"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:padding="4dp" />

                <TextView android:id="@+id/txtTotalCommands" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="دستورات اجرا شده: 0"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:padding="4dp" />

                <TextView android:id="@+id/txtTotalResets" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="تعداد ریست‌ها: 0"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:padding="4dp" />

                <TextView android:id="@+id/txtTotalSMS" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="پیامک‌های ارسال: 0"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:padding="4dp" />

                <TextView android:id="@+id/txtAvgVoltage" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="میانگین ولتاژ: 0V"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:padding="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:id="@+id/txtTotalScenes" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="سناریوها: 0"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:padding="4dp" />

                <TextView android:id="@+id/txtTotalTimers" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="تایمرها: 0"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:padding="4dp" />

                <TextView android:id="@+id/txtTotalSchedules" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="زمان‌بندی‌ها: 0"
                    android:textColor="@color/text_primary" android:textSize="14sp"
                    android:padding="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>